import sys
from collections import defaultdict
from scapy.all import sniff, IP, TCP

# Threshold configurations for malicious behavior tracking
PORT_SCAN_THRESHOLD = 20
connection_attempts = defaultdict(set)

def ids_rule_engine(packet):
    if IP in packet and TCP in packet:
        src_ip = packet[IP].src
        dst_ip = packet[IP].dst
        dst_port = packet[TCP].dport
        flags = packet[TCP].flags

        # Rule 1: Detection of Port Scanning activity
        connection_attempts[src_ip].add(dst_port)
        if len(connection_attempts[src_ip]) > PORT_SCAN_THRESHOLD:
            print(f"[!!! ALERT !!!] Intrusion Detected: Port Scan Activity from IP: {src_ip}")
            print(f"                Targeted unique ports count: {len(connection_attempts[src_ip])}")
            # Reset tracker to avoid alert flooding
            connection_attempts[src_ip].clear()

        # Rule 2: Detection of unauthorized SSH connection attempts
        if dst_port == 22:
            print(f"[! WARNING !] Suspicious Traffic: Potential SSH Attempt from {src_ip} to {dst_ip}")

        # Rule 3: Detection of Null Scan (TCP Flags are all empty/zeros)
        if flags == 0:
            print(f"[!!! ALERT !!!] Intrusion Detected: Stealth NULL Scan signature from IP: {src_ip}")

def main():
    print("====== CodeAlpha Network Intrusion Detection System (IDS) ======")
    print("[*] Monitoring network interface for signatures... Press Ctrl+C to stop.")
    
    try:
        sniff(prn=ids_rule_engine, store=False)
    except KeyboardInterrupt:
        print("\n[*] IDS shutting down safely.")
        sys.exit(0)
    except PermissionError:
        print("\n[!] Error: Root/Administrator privileges required to run the IDS.")
        sys.exit(1)

if __name__ == "__main__":
    main()